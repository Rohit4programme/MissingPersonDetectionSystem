APP_NAME="Missing Person Detection System"
APP_ENV=local
APP_KEY=base64:GENERATE_APP_KEY
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=database
DB_PORT=3306
DB_DATABASE=mpds
DB_USERNAME=mpds_user
DB_PASSWORD=mpds_secret

BROADCAST_DRIVER=reverb
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@mpds.gov"
MAIL_FROM_NAME="${APP_NAME}"

# Pusher / Reverb
PUSHER_APP_ID=mpds-app
PUSHER_APP_KEY=mpds-key
PUSHER_APP_SECRET=mpds-secret
PUSHER_HOST=websocket
PUSHER_PORT=6001
PUSHER_SCHEME=http

# AI Service
AI_SERVICE_URL=http://ai-service:5000

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Twilio SMS
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# WhatsApp
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
